function calculateHurstMatrix1() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sourceSheet = ss.getSheetByName("Sheet7"); 
  
  // 1. Get log returns from Column G (Row 2 down to last row)
  var lastRow = sourceSheet.getLastRow();
  var logReturns = sourceSheet.getRange(2, 7, lastRow - 1, 1).getValues().map(function(row) {
    return row[0];
  }).filter(function(val) {
    return val !== "" && !isNaN(val);
  });
  
  var totalLength = logReturns.length;
  if (totalLength < 7) {
    SpreadsheetApp.getUi().alert("Not enough data in Column G to process calculations.");
    return;
  }

  // Define the matrix window sizes requested
  var windows = [7, 14, 21, 28, 90, 120];
  var summaryData = [["Window Size (n)", "Log10(n)", "Avg R/S Matrix", "Log10(Avg R/S)"]];
  
  // 2. Loop through each individual matrix window size
  for (var w = 0; w < windows.length; w++) {
    var n = windows[w];
    if (n > totalLength) continue; // Skip windows larger than total historical data
    
    var rsValues = [];
    
    // Rolling R/S calculation for window size n
    for (var i = 0; i <= totalLength - n; i++) {
      var subSeries = logReturns.slice(i, i + n);
      var rs = computeSingleRS(subSeries);
      if (rs !== null) rsValues.push(rs);
    }
    
    // Average the R/S values for this window timeframe and apply logs
    if (rsValues.length > 0) {
      var avgRS = rsValues.reduce((a, b) => a + b, 0) / rsValues.length;
      summaryData.push([n, Math.log10(n), avgRS, Math.log10(avgRS)]);
    }
  }
  
  // 3. Calculate "Whole Time" Hurst explicitly using full history as a single window
  var wholeTimeRS = computeSingleRS(logReturns);
  
  // 4. Output results to the Summary tab
  var outputSheet = ss.getSheetByName("Hurst Summary");
  if (!outputSheet) {
    outputSheet = ss.insertSheet("Hurst Summary");
  } else {
    outputSheet.clear();
  }
  
  // Paste Matrix Table
  outputSheet.getRange(1, 1, summaryData.length, 4).setValues(summaryData);
  var matrixLastRow = summaryData.length;
  
  // Paste Whole Time Metrics off to the side
  outputSheet.getRange("F2").setValue("Whole Time Data Points (N):");
  outputSheet.getRange("G2").setValue(totalLength);
  outputSheet.getRange("F3").setValue("Whole Time Full R/S:");
  outputSheet.getRange("G3").setValue(wholeTimeRS);
  outputSheet.getRange("F4").setValue("Whole Time Hurst (H):");
  // Formally: H = log(R/S) / log(N) assuming C ≈ 1 for the raw full series limit
  outputSheet.getRange("G4").setFormula("=LOG10(G3)/LOG10(G2)");
  
  // Paste Matrix-Derived Hurst Formula using SLOPE
  outputSheet.getRange("F7").setValue("Matrix Hurst Exponent (H):");
  outputSheet.getRange("G7").setFormula("=SLOPE(D2:D" + matrixLastRow + ", B2:B" + matrixLastRow + ")");
  
  SpreadsheetApp.getUi().alert("Hurst Summary updated with new timeframes successfully!");
}

// Helper function to calculate R/S for a single discrete array of data
function computeSingleRS(series) {
  var n = series.length;
  var mean = series.reduce((a, b) => a + b, 0) / n;
  
  var cumDev = 0;
  var maxDev = 0;
  var minDev = 0;
  var sumSqDist = 0;
  
  for (var j = 0; j < n; j++) {
    var dev = series[j] - mean;
    cumDev += dev;
    if (cumDev > maxDev) maxDev = cumDev;
    if (cumDev < minDev) minDev = cumDev;
    
    sumSqDist += Math.pow(dev, 2);
  }
  
  var range = maxDev - minDev;
  var stDev = Math.sqrt(sumSqDist / (n - 1)); // Sample stdev
  
  return (stDev > 0) ? (range / stDev) : null;
}
