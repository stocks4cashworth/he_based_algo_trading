function extractEmails() {
  // 1. Define your labels here
  const labelsToProcess = ['Hedgeye/Macroshow', 'Hedgeye/TheCall']; 

  const processedLabelName = 'complete';
  
  const doc = DocumentApp.getActiveDocument();
  const body = doc.getBody();
  const completedLabel = GmailApp.getUserLabelByName(processedLabelName) || GmailApp.createLabel(processedLabelName);

  labelsToProcess.forEach(labelName => {
    // Search query: Specific label AND NOT complete
    const searchQuery = `label:${labelName} -label:${processedLabelName}`;
    const threads = GmailApp.search(searchQuery);
    
    if (threads.length === 0) return;

    threads.forEach(thread => {
      const messages = thread.getMessages();
      
      messages.forEach(message => {
        const subject = message.getSubject();
        const date = message.getDate();
        let content = message.getPlainBody().trim() || message.getBody().replace(/<[^>]*>?/gm, ' ');

        // 2. Insert at the top (Index 0)
        // We insert in reverse order so the header stays above the content
        body.insertHorizontalRule(0);
        body.insertParagraph(0, content);
        body.insertParagraph(0, `Date: ${date} | Label: ${labelName}`).setItalic(true);
        body.insertParagraph(0, subject).setHeading(DocumentApp.ParagraphHeading.HEADING2);
      });

      // Mark as complete
      thread.addLabel(completedLabel);
    });
  });

  DocumentApp.getUi().alert('New emails have been added to the top of the document.');
}
